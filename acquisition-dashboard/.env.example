VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
OPENAI_API_KEY=
DASHBOARD_EMAIL=
DASHBOARD_PASSWORD=
OFFICE365_CLIENT_ID=
# Optional: use a tenant ID or verified tenant domain instead of organizations.
OFFICE365_TENANT_ID=organizations
# Optional: defaults to ~/.cache/emc2ops/office365-msal-cache.json.
OFFICE365_TOKEN_CACHE=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Required for publishing to a Facebook Page from the Social Media Marketing tab.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Required for Instagram publishing. The account must be a professional account linked to the Page.
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional: defaults to v25.0.
META_GRAPH_API_VERSION=
# Optional: defaults to the local app origin, such as http://localhost:5173.
META_OAUTH_REDIRECT_URI=
# Optional: defaults to .meta-social-connections.json.
META_CONNECTIONS_FILE=
# Optional: comma-separated override for OAuth scopes.
META_OAUTH_SCOPES=
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
# Must match the callback URI in the X Developer Portal.
X_OAUTH_REDIRECT_URI=http://localhost:9876/auth/callback
# Optional: defaults to .x-social-connections.json.
X_CONNECTIONS_FILE=
